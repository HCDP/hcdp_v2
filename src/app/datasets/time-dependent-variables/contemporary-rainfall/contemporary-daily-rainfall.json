      "period": 1,
      "range": "query"
    },
    "data_layer_groups": {
      "data": {
        "label": "Daily Rainfall",
        "description": "Daily Rainfall Values",
        "data_range": {
          "standard": [0, 20],
          "extreme": [0, 250],
          "limits": [0, null]
        },
        "units": {
